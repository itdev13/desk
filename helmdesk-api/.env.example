# ── Server ──────────────────────────────────────────────────────────────────
PORT=3020
NODE_ENV=development
BASE_URL=http://localhost:3020
LOG_LEVEL=info

# ── Database (required) ───────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/helmdesk

# ── GoHighLevel OAuth (from the marketplace app settings) ─────────────────────
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
GHL_REDIRECT_URI=http://localhost:3020/oauth/callback
GHL_API_URL=https://services.leadconnectorhq.com
GHL_OAUTH_URL=https://services.leadconnectorhq.com/oauth
# Shared Secret used to decrypt the GHL Custom Page SSO user-context blob.
GHL_SSO_KEY=
# Marketplace App ID (from the app's dashboard) — required to charge the wallet for paid add-ons.
GHL_APP_ID=

# ── Session ───────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
SESSION_TTL=12h

# ── Subscription (monthly-only; GHL collects the fee) ─────────────────────────
# Map each GHL marketplace planId to a tier. seatLimit is informational/enforced in UI.
SUBSCRIPTION_REQUIRED=true
PLAN_NAME=Starter
PLAN_PRICE_USD=29
PLAN_SEAT_LIMIT=3
# PLANS_JSON={"<starterPlanId>":{"name":"Starter","priceUsd":29,"seatLimit":3},"<teamPlanId>":{"name":"Team","priceUsd":79,"seatLimit":10},"<agencyPlanId>":{"name":"Agency","priceUsd":99,"seatLimit":9999}}
# Optional per-tier feature bullets for the pricing page: add "features":["…","…"] inside a plan.
#
# The pricing page's "Upgrade" button deep-links to the app's plan page on the agency's OWN domain:
#   https://{domain}/v2/location/{locationId}/custom-page-link/{appId}
# The {domain} is captured per-agency at install (white-label domain); when absent it falls back to
# GHL_DEFAULT_APP_DOMAIN below. Set MARKETPLACE_UPGRADE_URL only to hard-override that entirely.
GHL_DEFAULT_APP_DOMAIN=app.gohighlevel.com
# The enrol/upgrade link is: https://{domain}/v2/location/{locationId}/integration/{appId}/versions/{versionId}
# Set this to your app's version id (from the marketplace app URL) so the enrol/upgrade button works.
GHL_APP_VERSION_ID=
MARKETPLACE_UPGRADE_URL=

# ── SLA monitor ────────────────────────────────────────────────────────────────
SLA_MONITOR=true
SLA_INTERVAL_MS=60000

# ── Product analytics / clickstream ───────────────────────────────────────────
# Master switch. false = the UI won't send events AND the API drops any it receives.
ANALYTICS_ENABLED=true
# Comma-separated locationIds to EXCLUDE from tracking (your own / internal / test locations).
# Enforced server-side even if a client tries to send.
ANALYTICS_EXCLUDED_LOCATION_IDS=

# ── Support tab ───────────────────────────────────────────────────────────────
# Contact-form email delivery (Gmail app password: https://myaccount.google.com/apppasswords).
# If unset, the contact form returns a friendly "not configured" message instead of crashing.
SUPPORT_EMAIL_USER=
SUPPORT_EMAIL_PASSWORD=
SUPPORT_EMAIL_TO=support@vaultsuite.store

# ── Paid onboarding call (one-time GHL wallet charge) ─────────────────────────
# Both the meter ID and the calendar URL must be set for the paid booking to appear.
# Create a per-unit meter in the marketplace app's Billing section, then paste its ID here.
GHL_ONBOARDING_METER_ID=
# true (default) = FIXED-price meter (price is set ON the meter in GHL; the app must NOT send a price).
# false = CUSTOM-price meter (the app sends ONBOARDING_CALL_PRICE_USD as the per-unit price).
GHL_ONBOARDING_METER_FIXED_PRICE=true
# Shown in the UI. For a FIXED-price meter this is display only — the real charge is the meter's price,
# so make sure the meter in GHL is set to this same amount.
ONBOARDING_CALL_PRICE_USD=2
ONBOARDING_CALL_MINS=30
# Scheduling link revealed after a successful charge (Google Calendar / Calendly).
ONBOARDING_CALENDAR_URL=
